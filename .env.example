# Home Park Real Estate - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_NAME="Home Park Real Estate"

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=realestatephp
DB_USERNAME=root
DB_PASSWORD=

# =============================================================================
# M-PESA (SAFARICOM DARAJA API) CONFIGURATION
# =============================================================================
# Get these from Safaricom Developer Portal: https://developer.safaricom.co.ke
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_shortcode
MPESA_MSISDN=your_test_msisdn
MPESA_PASSKEY=your_passkey
MPESA_INITIATOR_NAME=your_initiator_name
MPESA_INITIATOR_PASSWORD=your_initiator_password

# M-Pesa Callback URLs (must be HTTPS in production)
MPESA_STK_CALLBACK_URL=https://yourdomain.com/api/mpesa/stk_callback
MPESA_C2B_CALLBACK_URL=https://yourdomain.com/api/mpesa/c2b_callback
MPESA_B2C_CALLBACK_URL=https://yourdomain.com/api/mpesa/b2c_callback

# =============================================================================
# STRIPE PAYMENT CONFIGURATION
# =============================================================================
# Get these from Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_ENV=test
STRIPE_KEY=pk_test_your_publishable_key
STRIPE_SECRET=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Product Prices (in cents)
STRIPE_CURRENCY=usd
STRIPE_PREMIUM_PRICE_ID=price_your_premium_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price_id

# Stripe Webhook URL
STRIPE_WEBHOOK_URL=https://yourdomain.com/api/stripe/webhook

# =============================================================================
# PAYMENT SETTINGS
# =============================================================================
PAYMENT_CURRENCY=KES
PAYMENT_CURRENCY_SYMBOL=KSh
PAYMENT_CURRENCY_CODE=404

# Subscription Plans (in local currency)
SUBSCRIPTION_BASIC_PRICE=0
SUBSCRIPTION_BASIC_PROPERTIES=1

SUBSCRIPTION_PREMIUM_PRICE=2999
SUBSCRIPTION_PREMIUM_PROPERTIES=5

SUBSCRIPTION_ENTERPRISE_PRICE=9999
SUBSCRIPTION_ENTERPRISE_PROPERTIES=999999

# Payment Methods Enabled
ENABLE_MPESA=true
ENABLE_STRIPE=true

# =============================================================================
# EMAIL / MAIL CONFIGURATION
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@homestead.com
MAIL_FROM_NAME="Home Park Real Estate"

# =============================================================================
# CACHE & SESSION CONFIGURATION
# =============================================================================
CACHE_DRIVER=file
SESSION_DRIVER=file

# =============================================================================
# API KEYS (Optional: Google Maps, etc.)
# =============================================================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
